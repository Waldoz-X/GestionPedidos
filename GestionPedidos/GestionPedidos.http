@GestionPedidos_HostAddress = http://localhost:5135
@token = REEMPLAZAR_TOKEN
@clienteId = REEMPLAZAR_ID_CLIENTE
@empleadoId = REEMPLAZAR_ID_EMPLEADO
@productoId = REEMPLAZAR_ID_PRODUCTO
@estiloId = REEMPLAZAR_ID_ESTILO
@varianteId = REEMPLAZAR_ID_VARIANTE
@skuId = REEMPLAZAR_ID_SKU
@politicaId = REEMPLAZAR_ID_POLITICA
@precioId = REEMPLAZAR_ID_PRECIO
@pedidoId = REEMPLAZAR_ID_PEDIDO
@lineaPedidoId = REEMPLAZAR_ID_LINEA_PEDIDO
@usuarioClienteId = REEMPLAZAR_ID_USUARIO_CLIENTE
@paisCatalogoId = REEMPLAZAR_ID_PAIS
@areaCatalogoId = REEMPLAZAR_ID_AREA
@estadoCatalogoId = REEMPLAZAR_ID_ESTADO

POST {{GestionPedidos_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@gp.local",
  "password": "Admin1234"
}

###

GET {{GestionPedidos_HostAddress}}/api/auth/me
Authorization: Bearer {{token}}

###

